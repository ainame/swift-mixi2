# Copy this file to .env and fill in your values.
# cp .env.example .env

# Required
MIXI2_PUBLIC_KEY=       # Ed25519 public key as base64 (from mixi2 developer portal)
MIXI2_API_HOST=
MIXI2_TOKEN_URL=
MIXI2_CLIENT_ID=
MIXI2_CLIENT_SECRET=

# Optional
# MIXI2_API_PORT=443
# MIXI2_AUTH_KEY=
# MIXI2_WEBHOOK_PORT=8080
